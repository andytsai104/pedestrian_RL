{
  "simulation": {
    "town": "Town10HD",
    "fixed_delta_seconds": 0.05,
    "max_episode_steps": 500,
    "warmup_ticks": 10,

    "intersection": {
      "x": -43.5,
      "y": 21.0,
      "z": 0.0, 
      "dist": 25.0
    },

    "vehicle": {
      "veh_num": 40,
      "dist_to_intersection": 80,
      "speed_diff": 35,
      "dist_lead": 4,
      "wp_step": 5,
      "signal_ignoring_rate": 100    
    },

    "pedestrian":{
      "ped_num": 50,
      "speed_range": [0.9, 1.2]
    },

    "stuck_detection":{
      "time_out": 60,
      "pedestrian":{
        "dist": 25,
        "min_pedestrians": 8
      },
      "vehicle":{
        "velocity_threshold": 0.1,
        "stuck_time_limit": 5.0,
        "stuck_count_limit": 5
      }
    }
  
  },

  "bev": {
    "size": [160, 160],
    "range": 20,
    "hero_ped_size": 4,
    "other_ped_size": 3,
    "step_size": 0.4
  },

  "dataset": {
    "save_path": "datasets/pedestrian",
    "file_name": "pedestrian_dataset.h5",
    "num_episode": 20,
    "num_ped_per_episode": 12,
    "sample_every_n_steps": 4, 
    "format": "hdf5"
  }
}