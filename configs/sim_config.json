{
  "simulation": {
    "town": "Town10HD",
    "fixed_delta_seconds": 0.05,
    "max_episode_steps": 400,
    "warmup_ticks": 10,

    "intersection": {
      "x": -43.5,
      "y": 21.0,
      "z": 0.0, 
      "dist": 25.0
    },

    "vehicle": {
      "veh_num": 25,
      "dist_to_intersection": 50,
      "speed_diff": 50,
      "dist_lead": 2.0,
      "wp_step": 2    
    },

    "pedestrian":{
      "ped_num": 60,
      "speed_range": [0.5, 2]
    },

    "stuck_detection":{
      "time_out": 60,
      "pedestrian":{
        "dist": 25,
        "min_pedestrians": 15
      },
      "vehicle":{
        "velocity_threshold": 0.1,
        "stuck_time_limit": 5.0,
        "stuck_count_limit": 5
      }
    }
  
  },

  "bev": {
    "size": [160, 160],
    "range": 16
  },

  "dataset": {
    "save_path": "datasets/pedestrian",
    "file_name": "pedestrian_dataset_light.h5",
    "num_episode": 10,
    "num_ped_per_episode": 8,
    "sample_every_n_steps": 4, 
    "format": "hdf5"
  }
}