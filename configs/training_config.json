{
  "dataset_path": "datasets/pedestrian/pedestrian_dataset_light.h5",
  "media_dir": "media/bc",
  "checkpoint_dir": "checkpoints/bc",
  "params": {
    "batch_size": 64,
    "num_epochs": 40,
    "learning_rate": 0.0001,
    "num_workers": 12,
    "val_size": 0.15,
    "test_size": 0.10,
    "split_seed": 42,
    "seed_list": [1, 2, 3, 4, 5],
    "epoch_smooth_window": 0.5,
    "iteration_smooth_window": 10,
    "weight_decay": 0.0001,
    "grad_clip_norm": 1.0,
    "speed_loss_weight": 1.0,
    "direction_loss_weight": 1.0,
    "speed_tolerance": 0.2,
    "direction_tolerance_deg": 15.0,
    "goal_scale": 16.0,
    "direction_valid_speed_eps": 0.05
  },
  "cnn": {
    "bev_feature_dim": 128,
    "hidden_dim": 256,
    "direction_dim": 2,
    "dropout": 0.1
  }
}